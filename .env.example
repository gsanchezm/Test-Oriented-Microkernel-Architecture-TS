#############################################
# Execution Context
#############################################
# PLATFORM: web | android | ios | api  (drives locator resolution)
PLATFORM=web

# VIEWPORT (only when PLATFORM=web): desktop | responsive
VIEWPORT=desktop

# DRIVER picks the plugin that runs UI intents:
#   web-ui    → Playwright plugin
#   mobile-ui → Appium plugin
#   api       → no UI; molecules that depend on a browser self-skip
DRIVER=web-ui


#############################################
# Web Configuration (web-ui plugin → Playwright)
#############################################
BASE_URL=https://your-frontend-url.com
HEADLESS=false


#############################################
# API
#############################################
API_BASE_URL=https://your-backend-url.com

# Optional: override the login endpoint (defaults to /api/auth/login)
# LOGIN_API_URL=https://your-backend-url.com/api/auth/login

# X-Language header: en | es | de | fr | ja
LANGUAGE=en


#############################################
# Logging
#############################################
# pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info


#############################################
# Mobile-UI plugin → Appium server
# (the Appium HTTP server, not the plugin's own gRPC port — see below)
#############################################
APPIUM_HOST=localhost
APPIUM_PORT=4723

# Capability profile — filename without .json inside
# src/plugins/mobile-ui/capabilities/{android|ios}/
# android examples: galaxy_s25_ultra, docker_android
# ios examples:     iphone_17_pro
CAP_PROFILE=galaxy_s25_ultra

# Mobile App paths — overrides appium:app in the capability JSON (required for CI/Docker)
ANDROID_APP_PATH=assets/apps/android/app-release.apk
IOS_APP_PATH=assets/apps/ios/app-ios.zip

# Per-worker UDIDs for parallel sims — IOS_UDID_0, IOS_UDID_1, …
# IOS_UDID_0=auto


#############################################
# Android Emulator (docker-android)
# Used by `docker compose --profile mobile up`
# See: https://github.com/HQarroum/docker-android
#############################################
ANDROID_API_LEVEL=34
ANDROID_IMG_TYPE=google_apis
ANDROID_DEVICE_ID=pixel
ANDROID_EMULATOR_MEMORY=4096
ANDROID_EMULATOR_CORES=2


#############################################
# TOM Microkernel — Plugin gRPC Addresses
# Used by chaos-proxy to route intents to each plugin
#############################################
PROXY_ADDRESS=localhost:50051
WEB_UI_ADDRESS=localhost:50052
MOBILE_UI_ADDRESS=localhost:50053
PERFORMANCE_ADDRESS=localhost:50054
API_ADAPTER_ADDRESS=localhost:50055
VISUAL_ADDRESS=localhost:50056


#############################################
# TOM Microkernel — Plugin gRPC Listen Ports
# Used by each plugin server at startup
#############################################
WEB_UI_PORT=50052
MOBILE_UI_PORT=50053
API_PLUGIN_PORT=50055
PERFORMANCE_PORT=50054
VISUAL_PORT=50056


#############################################
# Performance (Gatling standalone simulations)
# pnpm perf:smoke | perf:load | perf:stress override PERF_PROFILE automatically
#############################################
# PERF_PROFILE: smoke | load | stress
PERF_PROFILE=smoke

# Virtual user count (load: ramp target, stress: at-once burst)
PERF_USERS=20

# Ramp duration in seconds (load profile only)
PERF_DURATION=120


#############################################
# TOM Plugin Registry
# Controls which plugins start via `pnpm run plugins`
#############################################
PLUGIN_WEB_UI=true
PLUGIN_MOBILE_UI=false
PLUGIN_API=true
PLUGIN_PERFORMANCE=false
PLUGIN_VISUAL=false
