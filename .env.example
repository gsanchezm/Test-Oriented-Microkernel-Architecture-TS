#############################################
# Execution Context
#############################################
# PLATFORM: web | android | ios | api  (drives locator resolution)
PLATFORM=web

# VIEWPORT (only when PLATFORM=web): desktop | responsive
VIEWPORT=desktop

# DRIVER picks the plugin that runs UI intents. Plugin identity = the tool
# under the hood, so multiple plugins can serve the same test type (e.g.
# `appium` and `mobilewright` both run mobile-UI intents — flip DRIVER to
# migrate a project without touching any feature, route, or action handler).
#   playwright   → Playwright (web UI)
#   appium       → Appium (mobile UI, legacy)
#   mobilewright → Playwright on mobile (new mobile path)
#   api          → no UI; molecules that depend on a browser self-skip
DRIVER=playwright


#############################################
# Web Configuration (playwright plugin)
#############################################
BASE_URL=https://your-frontend-url.com
HEADLESS=false


#############################################
# API
#############################################
API_BASE_URL=https://your-backend-url.com

# Optional: override the login endpoint (defaults to /api/auth/login)
# LOGIN_API_URL=https://your-backend-url.com/api/auth/login

# X-Language header: en | es | de | fr | ja
LANGUAGE=en


#############################################
# Logging
#############################################
# pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info


#############################################
# Appium plugin → Appium HTTP server
# (APPIUM_HOST/APPIUM_PORT point at the Appium daemon, not the plugin's
# own gRPC port — see TOM_PLUGIN section below)
#############################################
APPIUM_HOST=localhost
APPIUM_PORT=4723

# Capability profile — filename without .json inside
# src/plugins/appium/capabilities/{android|ios}/
# android examples: galaxy_s25_ultra, docker_android
# ios examples:     iphone_17_pro
DEVICE_PROFILE=galaxy_s25_ultra
# Multi-device parallel runs: comma-separated list, indexed by cucumber worker.
# DEVICE_PROFILES=huawei_y9,galaxy_s25_ultra,iphone_17_pro

# Mobile App paths — overrides appium:app in the capability JSON (required for CI/Docker)
ANDROID_APP_PATH=assets/apps/android/app-release.apk
IOS_APP_PATH=assets/apps/ios/app-ios.zip

# Per-worker UDIDs for parallel sims — IOS_UDID_0, IOS_UDID_1, …
# IOS_UDID_0=auto


#############################################
# Android Emulator (docker-android)
# Used by `docker compose --profile mobile up`
# See: https://github.com/HQarroum/docker-android
#############################################
ANDROID_API_LEVEL=34
ANDROID_IMG_TYPE=google_apis
ANDROID_DEVICE_ID=pixel
ANDROID_EMULATOR_MEMORY=4096
ANDROID_EMULATOR_CORES=2


#############################################
# TOM Microkernel — Plugin gRPC Addresses
# Used by chaos-proxy to route intents to each plugin
#############################################
PROXY_ADDRESS=localhost:50051
PLAYWRIGHT_ADDRESS=localhost:50052
APPIUM_ADDRESS=localhost:50053
GATLING_ADDRESS=localhost:50054
API_ADAPTER_ADDRESS=localhost:50055
PIXELMATCH_ADDRESS=localhost:50056
MOBILEWRIGHT_ADDRESS=localhost:50057


#############################################
# TOM Microkernel — Plugin gRPC Listen Ports
# Used by each plugin server at startup. `*_PLUGIN_PORT` is used (not
# `*_PORT`) to avoid collision with the tool's own port env vars — e.g.
# APPIUM_PORT=4723 is the Appium daemon; APPIUM_PLUGIN_PORT=50053 is the
# gRPC port the plugin binds to.
#############################################
PLAYWRIGHT_PLUGIN_PORT=50052
APPIUM_PLUGIN_PORT=50053
API_PLUGIN_PORT=50055
GATLING_PLUGIN_PORT=50054
PIXELMATCH_PLUGIN_PORT=50056
MOBILEWRIGHT_PLUGIN_PORT=50057


#############################################
# Performance (Gatling standalone simulations)
# pnpm perf:smoke | perf:load | perf:stress override PERF_PROFILE automatically
#############################################
# PERF_PROFILE: smoke | load | stress
PERF_PROFILE=smoke

# Virtual user count (load: ramp target, stress: at-once burst)
PERF_USERS=20

# Ramp duration in seconds (load profile only)
PERF_DURATION=120


#############################################
# TOM Plugin Registry
# Controls which plugins start via `pnpm run plugins`. Plugin identity = the
# tool, so a project can run legacy + new in parallel (or migrate by toggling).
#############################################
PLUGIN_PLAYWRIGHT=true
PLUGIN_APPIUM=false
PLUGIN_API=true
PLUGIN_GATLING=false
PLUGIN_PIXELMATCH=false
PLUGIN_MOBILEWRIGHT=false
