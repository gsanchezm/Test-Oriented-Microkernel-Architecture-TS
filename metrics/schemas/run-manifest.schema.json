{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tom-architecture/schemas/run-manifest.schema.json",
  "title": "RunManifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "runId",
    "generatedAt",
    "schemaVersion",
    "architectureType",
    "experimentBatchId",
    "runIndex",
    "repositoryName",
    "platform",
    "viewport",
    "driver",
    "environment",
    "nodeVersion",
    "os"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "runId": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "architectureType": { "type": "string", "description": "TOM for this repository; GTAA_BASELINE for the future baseline." },
    "experimentBatchId": { "type": "string" },
    "runIndex": { "type": "string" },
    "repositoryName": { "type": ["string", "null"] },
    "workflowName": { "type": ["string", "null"] },
    "workflowRunId": { "type": ["string", "null"] },
    "workflowAttempt": { "type": ["string", "null"] },
    "jobName": { "type": ["string", "null"] },
    "toolName": { "type": ["string", "null"] },
    "commitSha": { "type": ["string", "null"] },
    "branch": { "type": ["string", "null"] },
    "ciProvider": { "type": ["string", "null"] },
    "ciRunId": { "type": ["string", "null"] },
    "platform": { "type": "string" },
    "viewport": { "type": ["string", "null"] },
    "driver": { "type": ["string", "null"] },
    "startedAt": { "type": ["string", "null"] },
    "endedAt": { "type": ["string", "null"] },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "environment": { "type": ["string", "null"] },
    "nodeVersion": { "type": ["string", "null"] },
    "os": { "type": ["string", "null"] }
  }
}
