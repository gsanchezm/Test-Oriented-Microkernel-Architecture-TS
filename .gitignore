# visual-baselines/: the directory placeholder is tracked (via .gitkeep)
# but the PNGs inside are ignored locally — dev laptops generate their
# own baselines via `pnpm visual:refresh` for iteration without polluting
# the canonical set. The canonical baselines come from the
# update-visual-baselines.yml workflow which force-stages PNGs in the
# Linux container (mcr.microsoft.com/playwright:v1.58.2-jammy) and opens
# a PR. Both visual.yml and the refresh workflow watch
# visual-baselines/** so the trigger still fires when a PR ships
# regenerated baselines.
visual-baselines/*
!visual-baselines/.gitkeep

# Metrics pipeline output — schemas/summary stay tracked, runs are local
metrics/raw/**
!metrics/raw/
!metrics/raw/*/
!metrics/raw/**/.gitkeep
metrics/processed/**
!metrics/processed/
!metrics/processed/.gitkeep
metrics/figures/**
!metrics/figures/
!metrics/figures/.gitkeep

