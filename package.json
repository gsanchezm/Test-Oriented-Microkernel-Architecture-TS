{
  "name": "ahm-poc",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "proxy": "ts-node -r tsconfig-paths/register -r dotenv/config src/kernel/chaos-proxy.ts",
    "plugins": "ts-node -r tsconfig-paths/register src/kernel/start-plugins.ts",
    "plugin:web-ui": "ts-node -r tsconfig-paths/register -r dotenv/config src/plugins/web-ui/server.ts",
    "plugin:mobile-ui": "ts-node -r tsconfig-paths/register -r dotenv/config src/plugins/mobile-ui/server.ts",
    "plugin:api": "ts-node -r tsconfig-paths/register -r dotenv/config src/plugins/api/server.ts",
    "plugin:performance": "ts-node -r tsconfig-paths/register -r dotenv/config src/plugins/performance/server.ts",
    "plugin:visual": "ts-node -r tsconfig-paths/register -r dotenv/config src/plugins/visual/server.ts",
    "test": "cucumber-js",
    "perf:generate": "node -r tsconfig-paths/register node_modules/ts-node/dist/bin.js scripts/generate-checkout-feeder.ts",
    "preperf:smoke": "pnpm run perf:generate",
    "preperf:load": "pnpm run perf:generate",
    "preperf:stress": "pnpm run perf:generate",
    "perf:smoke": "PERF_PROFILE=smoke node -r dotenv/config node_modules/@gatling.io/cli/target/index.js run --sources-folder src/core/tests/checkout/simulations --simulation checkout-load",
    "perf:load": "PERF_PROFILE=load node -r dotenv/config node_modules/@gatling.io/cli/target/index.js run --sources-folder src/core/tests/checkout/simulations --simulation checkout-load",
    "perf:stress": "PERF_PROFILE=stress node -r dotenv/config node_modules/@gatling.io/cli/target/index.js run --sources-folder src/core/tests/checkout/simulations --simulation checkout-load",
    "metrics:manifest": "ts-node -r tsconfig-paths/register scripts/metrics/generate-run-manifest.ts",
    "metrics:inventory": "ts-node -r tsconfig-paths/register scripts/metrics/extract-scenario-inventory.ts",
    "metrics:coverage": "ts-node -r tsconfig-paths/register scripts/metrics/build-platform-coverage.ts",
    "metrics:normalize": "ts-node -r tsconfig-paths/register scripts/metrics/normalize-telemetry.ts",
    "metrics:durations": "ts-node -r tsconfig-paths/register scripts/metrics/aggregate-durations.ts",
    "metrics:tables": "ts-node -r tsconfig-paths/register scripts/metrics/build-article-tables.ts",
    "metrics:api": "ts-node -r tsconfig-paths/register scripts/metrics/normalize-api-contract-telemetry.ts",
    "metrics:visual": "ts-node -r tsconfig-paths/register scripts/metrics/normalize-visual-contract-telemetry.ts",
    "metrics:all": "pnpm run metrics:inventory && pnpm run metrics:coverage && pnpm run metrics:normalize && pnpm run metrics:durations && pnpm run metrics:api && pnpm run metrics:visual && pnpm run metrics:tables"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "20 || 22 || >=24"
  },
  "description": "",
  "dependencies": {
    "@gatling.io/core": "3.14.903",
    "@gatling.io/http": "3.14.903",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "appium": "^3.2.2",
    "minio": "^8.0.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "webdriverio": "^9.24.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.6.0",
    "@gatling.io/cli": "3.14.903",
    "@types/node": "^25.3.0",
    "@types/pino": "^7.0.5",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "appium-uiautomator2-driver": "^7.1.2",
    "appium-xcuitest-driver": "^11.0.0",
    "dotenv": "^17.3.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
