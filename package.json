{
  "name": "ahm",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "proxy": "ts-node -r tsconfig-paths/register -r dotenv/config src/kernel/chaos-proxy.ts",
    "plugins": "ts-node -r tsconfig-paths/register src/kernel/start-plugins.ts",
    "plugin:playwright": "ts-node -r tsconfig-paths/register -r dotenv/config src/plugins/playwright/server.ts",
    "plugin:appium": "ts-node -r tsconfig-paths/register -r dotenv/config src/plugins/appium/server.ts",
    "plugin:api": "ts-node -r tsconfig-paths/register -r dotenv/config src/plugins/api/server.ts",
    "plugin:gatling": "ts-node -r tsconfig-paths/register -r dotenv/config src/plugins/gatling/server.ts",
    "plugin:pixelmatch": "ts-node -r tsconfig-paths/register -r dotenv/config src/plugins/pixelmatch/server.ts",
    "plugin:mobilewright": "ts-node -r tsconfig-paths/register -r dotenv/config src/plugins/mobilewright/server.ts",
    "test": "cucumber-js",
    "test:json:api": "cucumber-js --tags \"@api\" --format json:reports/api.json",
    "test:json:playwright": "cucumber-js --tags \"@desktop or @responsive\" --format json:reports/playwright.json",
    "test:json:web:desktop": "node scripts/run-web-suite.js desktop",
    "test:json:web:responsive": "node scripts/run-web-suite.js responsive",
    "test:json:visual:desktop": "node scripts/visual-regen.js desktop",
    "test:json:visual:responsive": "node scripts/visual-regen.js responsive",
    "test:json:visual:compare:desktop": "cross-env PLUGIN_PIXELMATCH=true cucumber-js --tags \"@desktop and @visual\" --format json:reports/playwright-visual-desktop.json",
    "test:json:visual:compare:responsive": "cross-env PLUGIN_PIXELMATCH=true cucumber-js --tags \"@responsive and @visual\" --format json:reports/playwright-visual-responsive.json",
    "test:json:android": "cucumber-js --tags \"@android\" --format json:reports/android.json",
    "test:json:ios": "cucumber-js --tags \"@ios\" --format json:reports/ios.json",
    "test:report:verify": "node scripts/report/verify-report.js",
    "visual:refresh": "node scripts/visual-refresh.js",
    "perf:generate": "node -r tsconfig-paths/register node_modules/ts-node/dist/bin.js scripts/generate-checkout-feeder.ts",
    "preperf:smoke": "pnpm run perf:generate",
    "preperf:load": "pnpm run perf:generate",
    "preperf:stress": "pnpm run perf:generate",
    "perf:smoke": "cross-env PERF_PROFILE=smoke node -r dotenv/config node_modules/@gatling.io/cli/target/index.js run --sources-folder src/core/tests/checkout/resonance --simulation checkout-load",
    "perf:load": "cross-env PERF_PROFILE=load node -r dotenv/config node_modules/@gatling.io/cli/target/index.js run --sources-folder src/core/tests/checkout/resonance --simulation checkout-load",
    "perf:stress": "cross-env PERF_PROFILE=stress node -r dotenv/config node_modules/@gatling.io/cli/target/index.js run --sources-folder src/core/tests/checkout/resonance --simulation checkout-load",
    "perf:login-invalid:smoke": "cross-env PERF_PROFILE=smoke node -r dotenv/config node_modules/@gatling.io/cli/target/index.js run --sources-folder src/core/tests/login/resonance --simulation invalid-login-load",
    "perf:login-invalid:load": "cross-env PERF_PROFILE=load node -r dotenv/config node_modules/@gatling.io/cli/target/index.js run --sources-folder src/core/tests/login/resonance --simulation invalid-login-load",
    "perf:login-invalid:stress": "cross-env PERF_PROFILE=stress node -r dotenv/config node_modules/@gatling.io/cli/target/index.js run --sources-folder src/core/tests/login/resonance --simulation invalid-login-load",
    "metrics:manifest": "ts-node -r tsconfig-paths/register scripts/metrics/generate-run-manifest.ts",
    "metrics:inventory": "ts-node -r tsconfig-paths/register scripts/metrics/extract-scenario-inventory.ts",
    "metrics:coverage": "ts-node -r tsconfig-paths/register scripts/metrics/build-platform-coverage.ts",
    "metrics:normalize": "ts-node -r tsconfig-paths/register scripts/metrics/normalize-telemetry.ts",
    "metrics:durations": "ts-node -r tsconfig-paths/register scripts/metrics/aggregate-durations.ts",
    "metrics:tables": "ts-node -r tsconfig-paths/register scripts/metrics/build-article-tables.ts",
    "metrics:api": "ts-node -r tsconfig-paths/register scripts/metrics/normalize-api-contract-telemetry.ts",
    "metrics:visual": "ts-node -r tsconfig-paths/register scripts/metrics/normalize-visual-contract-telemetry.ts",
    "metrics:all": "pnpm run metrics:inventory && pnpm run metrics:coverage && pnpm run metrics:normalize && pnpm run metrics:durations && pnpm run metrics:api && pnpm run metrics:visual && pnpm run metrics:tables",
    "dashboard": "pnpm --filter dashboard dev",
    "dashboard:build": "pnpm --filter dashboard build",
    "dashboard:fixtures": "pnpm --filter dashboard fixtures:generate",
    "dashboard:ingest": "pnpm --filter dashboard ingest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "engines": {
    "node": "20 || 22 || >=24"
  },
  "description": "",
  "dependencies": {
    "@gatling.io/core": "3.14.903",
    "@gatling.io/http": "3.14.903",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.1",
    "appium": "^3.4.2",
    "minio": "^8.0.7",
    "mobilewright": "^0.0.31",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "webdriverio": "^9.27.1"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.3",
    "@gatling.io/cli": "3.14.903",
    "@types/node": "^25.7.0",
    "@types/pino": "^7.0.5",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "appium-uiautomator2-driver": "^7.3.0",
    "appium-xcuitest-driver": "^11.4.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
